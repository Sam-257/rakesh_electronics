{
  "name": "rakesh_electronics",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,vite -c blue,green \"node server/index.js\" \"vite\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "build": "npm run build:client && npm run build:server && npm run prerender",
    "start": "concurrently -n api,preview -c blue,green \"node server/index.js\" \"vite preview\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "prerender": "node scripts/prerender.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.96.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "formik": "^2.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.2",
    "yup": "^1.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.13.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "typescript": "^6.0.2",
    "vite": "^5.4.10"
  }
}
